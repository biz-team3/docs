#   "previewComments": []
# }

### 게시물 생성 실패 - 이미지 없음
POST {{baseUrl}}/api/posts
Authorization: Bearer {{accessToken}}
Content-Type: application/json

{
  "media": [],
  "caption": "이미지 없음"
}

# Error Response: 400 Bad Request
# {
#   "code": "POST_MEDIA_REQUIRED",
#   "message": "게시물 이미지는 최소 1장 이상 필요합니다."
