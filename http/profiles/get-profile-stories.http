# ============================================================
# API: 프로필 스토리 조회
# Method: GET
# Endpoint: /api/profiles/users/{userId}/stories
# Auth: 필요
# Content-Type: application/json
# Description:
# - 특정 사용자의 프로필 기준 스토리 목록을 조회한다.
# - 비공개 계정의 접근 권한을 canViewContent로 함께 반환한다.
# ============================================================

@baseUrl = http://localhost:8080
@accessToken = replace-me
@userId = 1

# Path Parameters
# - userId: number, required
#
# 제한 조건
# - 비공개 계정이고 팔로잉이 아니면 stories는 빈 배열이다.
# - 만료된 스토리는 반환하지 않는다.
#
# 테스트 필요 조건
# - 내 스토리 조회
# - 팔로잉 공개/비공개 계정 스토리 조회
# - 비공개/미팔로우 계정 빈 배열

### 프로필 스토리 조회
GET {{baseUrl}}/api/profiles/users/{{userId}}/stories
Authorization: Bearer {{accessToken}}

# Success Response: 200 OK
# {
#   "userId": 1,
#   "canViewContent": true,
#   "stories": [
#     {
#       "storyId": 101,
#       "userId": 1,
#       "imageUrl": "/oosu.hada.jpg",
#       "createdAtText": "now"
#     }
#   ]
# }

### 프로필 스토리 조회 실패 - 사용자 없음
GET {{baseUrl}}/api/profiles/users/999999/stories
Authorization: Bearer {{accessToken}}

# Error Response: 404 Not Found
# {
#   "code": "USER_NOT_FOUND",
#   "message": "사용자를 찾을 수 없습니다."
# }
